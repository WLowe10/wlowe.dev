{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "strictNullChecks": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": "./src",
    "paths": {
      "@constants": ["./constants.ts"],
      "@assets": ["./assets/index"],
      "@assets/*": ["./assets/*"],
      "@utils": ["./utils/index"],
      "@utils/*": ["./utils/*"],
      "@components": ["./components"],
      "@components/*": ["./components/*"],
      "@layouts": ["./layouts/index"],
      "@layouts/*": ["./layouts/*"],
      "@features": ["./features/index"],
      "@features/*": ["./features/*"],
    }
  }
}