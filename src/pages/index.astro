---
import BlogLink from "../components/BlogLink.astro";
import Layout from '@layouts/Layout.astro';
import { getBlogs } from "@utils";

const blogs = await getBlogs();
---

<Layout class="bg-slate-50">
	<main class="px-6 mt-14 max-w-3xl mx-auto">
		<h1 class="text-4xl font-bold mb-2 lg:text-5xl">
			Wes Lowe
		</h1>	
		<div class="mb-6">
			<p class="text-lg">
				Hey! I'm Wes, a full stack developer with a love for coding and creating elegant applications. 
				I'm currently working on 
				<span class="text-purple-500">Potion</span> and I've embedded an exclusive demo below!
				Thanks for checking out my portfolio.
			</p>
			<span class="text-xs text-slate-500">
				Wes Lowe -
				<time>
					12/11/2023
				</time>
			</span>
		</div>

		<h2 class="font-semibold text-lg mb-2">
			{`${blogs.length} blog${blogs.length !== 1 ? 's' : ''}`}
		</h2>
		<div class="flex flex-col gap-4">
			{
				blogs.map(blog => <BlogLink {...blog} />)
			}
		</div>
</Layout>
