---
type Props = {
  id: string;
};

const props = Astro.props;
---

<iframe
    loading="lazy"
    width="560"
    height="315"
    src={`https://www.youtube.com/embed/${props.id}`}
    frameborder="0"
    allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture"
    allowfullscreen 
/>