---
import { readingTime } from "@utils";
import type { CollectionEntry } from "astro:content";

export type Props = CollectionEntry<"blog">;

const { data, slug, body } = Astro.props;
---

<a href={`./blogs/${slug}`}>
    <div class="flex flex-col">
        <p>
            {
                data.title
            }
        </p>
    </div>

    <ul class="flex">
        <li>
            {`${readingTime("test")} min read`}
        </li>
        {
            data.tags.map(tag => (
                <li>
                    {tag}
                </li>
            ))
        }
    </ul>
</div>